# Copy to .env and fill values as needed.
#
# IMPORTANT:
# - This backend is configured for PostgreSQL + PostGIS.
# - Prefer setting DATABASE_URL instead of individual DB_* vars.
#
# Example PostgreSQL URL format:
#   postgres://traveller:traveller@localhost:5432/traveller?sslmode=disable

# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# Database (preferred)
DATABASE_URL=

# Database (fallback if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=traveller
DB_PASSWORD=traveller
DB_NAME=traveller
DB_SSLMODE=disable

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# GTFS Data
GTFS_DATA_PATH=../DMRC_GTFS
